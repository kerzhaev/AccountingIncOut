<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="tabUchetVhIsh" label="IncOut" insertAfterMso="TabData">
        
        <group id="grpProcessing" label="Data Processing">
          <button id="btnMassProcess" 
                  label="📊 Mass Processing" 
                  size="large" 
                  onAction="RibbonCallbacks.btnMassProcess_Click"
                  screentip="Mass processing of records"
                  supertip="Automatic matching of all IncOut records with 1C postings"/>
          
          <separator id="sep1"/>
          
          <button id="btnMatchDoverennosti" 
                  label="🔗 Match Doverennosti" 
                  size="large" 
                  onAction="RibbonCallbacks.btnMatchDoverennosti_Click"
                  screentip="Doverennosti Matching"
                  supertip="Search for matches between doverennosti and operations"/>
        </group>
        
        <group id="grpAnalysis" label="Analysis and Reports">
          <button id="btnStatistics" 
                  label="📈 Statistics" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnStatistics_Click"
                  screentip="Integration Statistics"
                  supertip="Report on 1C matching results"/>
          
          <button id="btnAnalyzeOperations" 
                  label="🔍 Analyze Operations" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnAnalyzeOperations_Click"
                  screentip="Operations Analysis"
                  supertip="Detailed analysis of operations and workflow"/>
          
          <button id="btnShowLog" 
                  label="📋 Log" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnShowLog_Click"
                  screentip="Operation Log"
                  supertip="View the log of all executed operations"/>
                  
          <separator id="sep3"/>
          
          <button id="btnGenerateWordLetters" 
                  label="📝 Doverennosti Letters" 
                  size="large" 
                  onAction="RibbonCallbacks.btnGenerateWordLetters_Click"
                  screentip="Generate Letters"
                  supertip="Create Word documents with letters for unmatched doverennosti"/>
                  
        </group>
        
        <group id="grpManagement" label="Management">
          <button id="btnSettings" 
                  label="⚙️ Settings" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnSettings_Click"
                  screentip="System Settings"
                  supertip="Configuration of system parameters"/>
          
          <button id="btnClearMarks" 
                  label="🗑️ Clear Marks" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnClearMarks_Click"
                  screentip="Clear Marks"
                  supertip="Clear all execution marks"/>
          
          <separator id="sep2"/>
          
          <button id="btnBackupManager" 
                  label="💾 Backups" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnBackupManager_Click"
                  screentip="Backup Manager"
                  supertip="Manage backup copies"/>
          
          <button id="btnHelp" 
                  label="❓ Help" 
                  size="normal" 
                  onAction="RibbonCallbacks.btnHelp_Click"
                  screentip="Help"
                  supertip="System usage help"/>
        </group>
        
      </tab>
    </tabs>
  </ribbon>
</customUI>